{
  "name": "codex-notification-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram remote control for existing local Codex sessions.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "smoke:codex": "tsx scripts/smoke-codex.ts"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "grammy": "^1.38.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
